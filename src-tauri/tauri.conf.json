{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Inowio-D2d",
  "version": "0.1.0",
  "identifier": "in.inowio.d2d",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Inowio - D2d (Data Conversion Toolkit)",
        "width": 1280,
        "height": 720,
        "maximized": true,
        "theme": "Dark",
        "devtools": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "copyright": "Inowio Technologies LLP",
    "longDescription": "D2d - Data Conversion Toolkit",
    "homepage": "https://inowio.in",
    "publisher": "Inowio Technologies LLP",
    "shortDescription": "Data Conversion Toolkit",
    "license": "MIT",
    "category": "Utility",
    "windows": {
      "allowDowngrades": true,
      "certificateThumbprint": null,
      "digestAlgorithm": null,
      "nsis": null,
      "signCommand": null,
      "timestampUrl": null,
      "tsp": false,
      "webviewInstallMode": {
        "silent": true,
        "type": "offlineInstaller"
      },
      "wix": null
    }
  }
}
